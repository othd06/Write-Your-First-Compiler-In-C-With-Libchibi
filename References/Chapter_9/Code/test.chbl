(extern proc (puts (i32 ((string s)))))

(define proc
  (main (i32 ())
    (body
      (var (i32 fails))
      (assign fails (i32 0))

      ; basic arithmetic;
      (var (i32 a))
      (var (i32 b))
      (assign a (i32 12))
      (assign b (i32 5))

      (if (= (+ a b) (i32 17)) (body) 
      else (assign fails (+ fails (i32 1))))

      (if (= (- a b) (i32 7)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (* a b) (i32 60)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (/ a b) (i32 2)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (% a b) (i32 2)) (body)
      else (assign fails (+ fails (i32 1))))

      ; comparisons;
      (if (log and (= a (i32 12)) (/= a b)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (> a b) (body)
      else (assign fails (+ fails (i32 1))))

      (if (>= a (i32 12)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (< b a) (body)
      else (assign fails (+ fails (i32 1))))

      (if (<= b (i32 5)) (body)
      else (assign fails (+ fails (i32 1))))

      ; boolean / logical;
      (var (bool t))
      (var (bool f))
      (assign t (bool true))
      (assign f (bool false))

      (if (log and (bool true) (bool true)) (body)
      else (assign fails (+ fails (i32 1)))) 
      
      (if (log and (log not (bool false)) (bool true)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (log and t (log not f)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (log or f t) (body)
      else (assign fails (+ fails (i32 1))))

      (if (log xor t f) (body)
      else (assign fails (+ fails (i32 1))))

      ; bitwise;
      (if (= (bit and (u32 6) (u32 3)) (u32 2)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (bit or (u32 6) (u32 3)) (u32 7)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (bit xor (u32 6) (u32 3)) (u32 5)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (shl (u32 1) (u32 3)) (u32 8)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (shr (u32 8) (u32 2)) (u32 2)) (body)
      else (assign fails (+ fails (i32 1))))

      ; bit-not is easiest to smoke-test via a known value;
      (if (= (bit not (u32 0)) (u32 4294967295)) (body)
      else (assign fails (+ fails (i32 1))))

      ; casts;
      (if (= (cast i32 (u32 9)) (i32 9)) (body)
      else (assign fails (+ fails (i32 1))))

      (if (= (cast u32 (i32 9)) (u32 9)) (body)
      else (assign fails (+ fails (i32 1))))

      ; pointers;
      (var ((ptr i32) p))
      (assign p (ptr to a))

      (if (= (from ptr p) a) (body)
      else (assign fails (+ fails (i32 1))))

      ; allocation / free smoke test;
      (var ((ptr i32) q))
      (assign q (allocate (i32 99) of i8))
      (free q)

      ; if / elif / else;
      (if (= (i32 0) (i32 1)) (assign fails (+ fails (i32 1)))
      elif (= (i32 1) (i32 0)) (assign fails (+ fails (i32 1)))
      else (body)) 

      ; while / continue / break;
      (var (i32 i))
      (var (i32 seen))
      (assign i (i32 0))
      (assign seen (i32 0)) 

      (while (< i (i32 10))
        (body
          (assign i (+ i (i32 1)))

          (if (= (% i (i32 2)) (i32 0)) continue)

          (assign seen (+ seen (i32 1)))

          (if (= seen (i32 3)) break)
        )
      ) 

      (if (= seen (i32 3)) (body)
      else (assign fails (+ fails (i32 1))))

      ; string literal + FFI smoke test;
      (puts (string "feature-test ok"))


      (return fails))))